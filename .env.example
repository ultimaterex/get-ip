# Copy to `.env` (gitignored) before `docker compose up`, or export these in your shell.
# Optional — enables GeoLite2-City download on startup when both are set.

MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# Optional:
# GEOLITE_MAX_AGE_DAYS=7
# GEOLITE_ASN_PATH=/data/GeoLite2-ASN.mmdb
#
# Live DNSBL checks (see README — DNS blocklists; examples in documentation/dnsbl-examples.md)
# DNSBL_ZONES="zen.spamhaus.org|spamhaus-zen;bl.spamcop.net|spamcop"
# DNSBL_DEADLINE=30s
# DNSBL_CACHE_TTL=15m
# DNSBL_CLIENT_MAX=30
# DNSBL_CLIENT_WINDOW=1h
# DNSBL_GLOBAL_MAX_PER_MINUTE=120
