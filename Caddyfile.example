# Replace ip.example.tld and the upstream with yours.
# Plain "curl ip.example.tld" uses http:// on port 80. If only HTTPS is served with an
# HTTP→HTTPS redirect, curl without -L gets an empty/minimal body. Define BOTH schemes
# so port 80 proxies to the app instead of redirecting.

http://ip.example.tld {
	encode gzip
	reverse_proxy 127.0.0.1:8080
}

https://ip.example.tld {
	encode gzip
	reverse_proxy 127.0.0.1:8080
}
